{
  "name": "ppgp-backend-window",
  "version": "1.0.0",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder"
  },
  "build": {
    "appId": "com.ppgp.backendwindow",
    "productName": "PPGP Backend Window",
    "directories": {
      "output": "dist"
    },
    "files": [
      "**/*",
      "python/**/*"
    ],
    "asarUnpack": [
      "**/python/**"
    ],
    "win": {
      "target": "nsis",
      "forceCodeSigning": false,
      "signAndEditExecutable": false
    }
  },
  "devDependencies": {
    "electron": "^28.0.0",
    "electron-builder": "^26.8.1"
  }
}
