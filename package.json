{
  "name": "ppgp-desktop-frontend",
  "version": "1.0.0",
  "private": true,
  "main": "electron/main.cjs",
  "scripts": {
    "dev": "concurrently -k \"npm:dev:vite\" \"npm:dev:electron\"",
    "dev:vite": "vite",
    "dev:electron": "wait-on http://127.0.0.1:5173 && electronmon .",
    "build": "vite build",
    "start": "electron ."
  },
  "dependencies": {
    "@vitejs/plugin-react": "^6.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hot-toast": "^2.6.0"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "elctron": "^0.0.1-security",
    "electron": "^30.0.0",
    "electronmon": "^2.0.0",
    "vite": "^8.0.7",
    "wait-on": "^7.0.1"
  }
}
